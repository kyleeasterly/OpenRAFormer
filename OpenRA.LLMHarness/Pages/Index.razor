@page "/"
@using OpenRA.LLMHarness.Services
@inject OllamaService OllamaService
@inject IJSRuntime JSRuntime
@implements IDisposable

<PageTitle>OpenRA LLM Coach</PageTitle>

<style>
    @@keyframes blink {
        0% { opacity: 1; }
        50% { opacity: 0; }
        100% { opacity: 1; }
    }
    
    .sidebar-transition {
        transition: all 0.3s ease-in-out;
    }
</style>

<script>
    window.scrollToStreamingCaret = function() {
        var caret = document.querySelector('.streaming-caret');
        if (caret) {
            caret.scrollIntoView({ behavior: 'smooth', block: 'end', inline: 'nearest' });
        }
    };
</script>

<MudGrid>
    <!-- Sidebar with session history -->
    @if (sidebarOpen)
    {
        <MudItem xs="3" Class="sidebar-transition">
        <MudPaper Elevation="3" Class="pa-4" Style="height: calc(100vh - 80px); overflow-y: auto;">
            <MudText Typo="Typo.h6" Class="mb-4">Session History</MudText>
            
            @if (sessionHistory.Count == 0)
            {
                <MudText Typo="Typo.body2" Color="Color.Secondary">No responses yet...</MudText>
            }
            else
            {
                <MudList Clickable="true">
                    @foreach (var response in sessionHistory.OrderByDescending(r => r.Timestamp))
                    {
                        <MudListItem OnClick="@(() => SelectResponse(response.Id))">
                            <MudCard Outlined="@(selectedResponseId == response.Id)" 
                                     Class="@(selectedResponseId == response.Id ? "mud-theme-primary" : "")">
                                <MudCardContent Class="py-2 px-3">
                                    <MudText Typo="Typo.caption">@response.Timestamp.ToString("HH:mm:ss")</MudText>
                                    <MudText Typo="Typo.body2" Class="text-truncate">
                                        @(response.Response.Length > 50 ? response.Response.Substring(0, 50) + "..." : response.Response)
                                    </MudText>
                                    <MudText Typo="Typo.caption" Color="Color.Secondary">
                                        @response.DurationSeconds.ToString("F1")s
                                    </MudText>
                                </MudCardContent>
                            </MudCard>
                        </MudListItem>
                    }
                </MudList>
            }
        </MudPaper>
    </MudItem>
    }
    
    <!-- Main content area -->
    <MudItem xs="@(sidebarOpen ? 9 : 12)" Class="sidebar-transition">
        <MudPaper Elevation="3" Class="pa-4" Style="height: calc(100vh - 80px); overflow-y: auto;">
            <!-- Status bar -->
            <MudAlert Severity="@(isConnected ? Severity.Success : Severity.Warning)" Class="mb-4">
                @statusMessage
            </MudAlert>
            
            <!-- Controls -->
            <MudGrid>
                <MudItem xs="12" sm="4">
                    <MudSwitch @bind-Value="@verboseMode" Label="Verbose Mode" Color="Color.Primary" />
                </MudItem>
                <MudItem xs="12" sm="4">
                    <MudSwitch Value="@writeOrdersToGame" ValueChanged="OnWriteOrdersToGameChanged" Label="Send Orders to Game" Color="Color.Primary" />
                </MudItem>
                <MudItem xs="12" sm="4">
                    <MudText Typo="Typo.subtitle2">Thinking Level:</MudText>
                    <MudRadioGroup Value="@thinkingLevel" T="string" ValueChanged="OnThinkingLevelChanged">
                        <MudRadio Value="@("low")" Color="Color.Primary" Size="Size.Small">Low</MudRadio>
                        <MudRadio Value="@("medium")" Color="Color.Primary" Size="Size.Small">Medium</MudRadio>
                        <MudRadio Value="@("high")" Color="Color.Primary" Size="Size.Small">High</MudRadio>
                    </MudRadioGroup>
                </MudItem>
            </MudGrid>
            <MudDivider Class="my-4" />
            
            <!-- Current response display -->
            <MudCard>
                <MudCardContent>
                    @if (isProcessing)
                    {
                        <MudText Typo="Typo.h6" Class="mb-2">LLM is processing...</MudText>
                        <MudProgressLinear Color="Color.Primary" Indeterminate="true" Class="mb-3" />
                    }
                    else if (!string.IsNullOrEmpty(selectedResponseId) && GetSelectedResponse() != null)
                    {
                        var selected = GetSelectedResponse()!;
                        <MudText Typo="Typo.h6" Class="mb-2">
                            Response from @selected.Timestamp.ToString("HH:mm:ss")
                        </MudText>
                        <MudDivider Class="my-2" />
                        
                        @if (verboseMode)
                        {
                            <MudExpansionPanels Class="mb-3">
                                <MudExpansionPanel Text="Game State">
                                    <MudText Typo="Typo.body2" Style="white-space: pre-wrap; font-family: monospace;">
                                        @selected.GameState
                                    </MudText>
                                </MudExpansionPanel>
                                @if (!string.IsNullOrEmpty(selected.Thinking))
                                {
                                    <MudExpansionPanel Text="Thinking Process">
                                        <MudText Typo="Typo.body2" Style="white-space: pre-wrap; font-family: monospace; color: #64b5f6;">
                                            @selected.Thinking
                                        </MudText>
                                    </MudExpansionPanel>
                                }
                            </MudExpansionPanels>
                        }
                        
                        <MudText Typo="Typo.body1" Style="white-space: pre-wrap;">
                            @selected.Response
                        </MudText>
                        
                        <MudDivider Class="my-2" />
                        <MudText Typo="Typo.caption" Color="Color.Secondary">
                            Generated in @selected.DurationSeconds.ToString("F1") seconds
                        </MudText>
                    }
                    else
                    {
                        <MudText Typo="Typo.h6">Waiting for game state...</MudText>
                        <MudText Typo="Typo.body2" Color="Color.Secondary">
                            The LLM will analyze game states as they are detected in the watch directory.
                        </MudText>
                    }
                    
                    <!-- Streaming display: Response first, then thinking below -->
                    @if (!string.IsNullOrEmpty(currentStreamingResponse))
                    {
                        <MudText Typo="Typo.body1" Style="white-space: pre-wrap;" Class="mt-3">
                            @currentStreamingResponse
                            @if (isProcessing)
                            {
                                <span class="streaming-caret" style="display: inline-block; width: 8px; height: 20px; background-color: #2196f3; animation: blink 1s infinite;">|</span>
                            }
                        </MudText>
                    }
                    
                    @if (!string.IsNullOrEmpty(currentStreamingThinking) || (!isProcessing && !string.IsNullOrEmpty(lastThinkingTrace)))
                    {
                        <MudCard Class="mt-3" Outlined="true" Style="background-color: #1e3a5f;">
                            <MudCardContent>
                                @if (isProcessing && showThinking)
                                {
                                    <MudText Typo="Typo.subtitle2" Color="Color.Info">Thinking...</MudText>
                                    <MudText Typo="Typo.body2" Style="white-space: pre-wrap; font-family: monospace; color: #64b5f6;">
                                        @currentStreamingThinking
                                    </MudText>
                                }
                                else if (!string.IsNullOrEmpty(lastThinkingTrace))
                                {
                                    <MudText Typo="Typo.subtitle2" Color="Color.Info">Thinking Process</MudText>
                                    <MudText Typo="Typo.body2" Style="white-space: pre-wrap; font-family: monospace; color: #64b5f6;">
                                        @lastThinkingTrace
                                    </MudText>
                                }
                            </MudCardContent>
                        </MudCard>
                    }
                </MudCardContent>
            </MudCard>
        </MudPaper>
    </MudItem>
</MudGrid>

@code {
    [CascadingParameter] private bool sidebarOpen { get; set; } = true;
    [CascadingParameter(Name = "ToggleSidebar")] private Action? ToggleSidebar { get; set; }
    
    private bool isConnected = false;
    private bool isProcessing = false;
    private bool verboseMode = false;
    private bool writeOrdersToGame = false;
    private string statusMessage = "Initializing...";
    private string selectedResponseId = "";
    private string currentStreamingResponse = "";
    private string currentStreamingThinking = "";
    private string lastThinkingTrace = "";
    private bool showThinking = false;
    private string thinkingLevel = "medium";
    
    private List<LLMResponse> sessionHistory = new();

    protected override async Task OnInitializedAsync()
    {
        // Subscribe to events
        OllamaService.OnResponseChunk += HandleResponseChunk;
        OllamaService.OnThinkingChunk += HandleThinkingChunk;
        OllamaService.OnResponseComplete += HandleResponseComplete;
        OllamaService.OnStatusUpdate += HandleStatusUpdate;
        
        // Set initial settings
        OllamaService.VerboseMode = verboseMode;
        OllamaService.ThinkingLevel = thinkingLevel;
        OllamaService.WriteOrdersToGame = writeOrdersToGame;
        
        await base.OnInitializedAsync();
    }

    private async Task HandleResponseChunk(string chunk)
    {
        currentStreamingResponse += chunk;
        isProcessing = true;
        showThinking = false; // Switch to showing response
        
        // Save thinking trace when response starts
        if (!string.IsNullOrEmpty(currentStreamingThinking) && string.IsNullOrEmpty(lastThinkingTrace))
        {
            lastThinkingTrace = currentStreamingThinking;
            // Don't collapse - let user control the expansion state
        }
        
        await InvokeAsync(StateHasChanged);
        
        // Auto-scroll to keep the streaming caret in view
        await JSRuntime.InvokeVoidAsync("scrollToStreamingCaret");
    }
    
    private async Task HandleThinkingChunk(string chunk)
    {
        currentStreamingThinking += chunk;
        isProcessing = true;
        showThinking = true; // Show thinking while it's being received
        await InvokeAsync(StateHasChanged);
    }

    private async Task HandleResponseComplete(LLMResponse response)
    {
        sessionHistory.Add(response);
        selectedResponseId = response.Id;
        currentStreamingResponse = "";
        currentStreamingThinking = "";
        lastThinkingTrace = response.Thinking; // Keep the thinking trace
        isProcessing = false;
        showThinking = false;
        await InvokeAsync(StateHasChanged);
    }
    
    private void OnThinkingLevelChanged(string newLevel)
    {
        thinkingLevel = newLevel;
        OllamaService.ThinkingLevel = thinkingLevel;
    }

    private async Task HandleStatusUpdate(string status)
    {
        statusMessage = status;
        if (status.Contains("API is responding"))
        {
            isConnected = true;
        }
        else if (status.Contains("Failed to connect"))
        {
            isConnected = false;
        }
        await InvokeAsync(StateHasChanged);
    }

    private void SelectResponse(string responseId)
    {
        selectedResponseId = responseId;
        currentStreamingResponse = "";
        currentStreamingThinking = "";
        showThinking = false;
        
        // Load thinking trace from selected response
        var selected = GetSelectedResponse();
        lastThinkingTrace = selected?.Thinking ?? "";
        // Keep the current expansion state when switching responses
    }

    private LLMResponse? GetSelectedResponse()
    {
        return sessionHistory.FirstOrDefault(r => r.Id == selectedResponseId);
    }

    private void OnVerboseModeChanged(bool newValue)
    {
        verboseMode = newValue;
        OllamaService.VerboseMode = verboseMode;
    }

    private void OnWriteOrdersToGameChanged(bool newValue)
    {
        writeOrdersToGame = newValue;
        OllamaService.WriteOrdersToGame = writeOrdersToGame;
    }

    public void Dispose()
    {
        // Unsubscribe from events
        OllamaService.OnResponseChunk -= HandleResponseChunk;
        OllamaService.OnThinkingChunk -= HandleThinkingChunk;
        OllamaService.OnResponseComplete -= HandleResponseComplete;
        OllamaService.OnStatusUpdate -= HandleStatusUpdate;
    }
}
